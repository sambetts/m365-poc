# Azure Speech TTS settings (set SpeechScriptFile to enable TTS mode instead of AV playback)
# Auth uses AadAppId/AadAppSecret/AadTenantId via RBAC - assign "Cognitive Services Speech User" role to the app
# SpeechResourceId and SpeechEndpoint are required. The Speech resource must have a custom subdomain enabled.
AzureSettings__SpeechRegion=eastus
AzureSettings__SpeechResourceId=
AzureSettings__SpeechEndpoint=
AzureSettings__SpeechVoiceName=en-US-AvaMultilingualNeural
AzureSettings__SpeechScriptFile=script.txt